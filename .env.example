SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (for embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# Rate Limiting (Vercel KV or Upstash)
KV_URL=
KV_REST_API_URL=
