# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Embeddings — Voyage AI (200M free tokens, no CC needed)
# Sign up at https://dashboard.voyageai.com
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-4

# Embeddings fallback — Google Gemini (free tier, 1,500 req/day)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# Rate Limiting (Vercel KV or Upstash)
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Payments — Base USDC wallet for x402 / credit purchases
# Create a wallet at https://base.org or use any self-custodial wallet
PAYMENT_WALLET_ADDRESS=0x...
CREDIT_PRICE_PER_THOUSAND=1.00
MIN_TOP_UP_CREDITS=100

# On-chain Payment Verification (uses Base RPC directly — no API key needed)
BASE_RPC_URL=https://mainnet.base.org
